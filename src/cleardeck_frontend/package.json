    "@dfinity/oisy-wallet-signer": "^4.1.0",
    "@dfinity/utils": "^4.1.0",
    "@icp-sdk/core": "^5.0.0"
  },
  "devDependencies": {
    "@icp-sdk/bindgen": "^0.3.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.46.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "sass": "^1.63.6",
    "svelte": "^5.39.9",
    "svelte-check": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.3"
