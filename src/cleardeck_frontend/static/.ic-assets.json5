[
    {
        "match": "**/*",

        // Disallow raw access — force certified asset responses
        "allow_raw_access": false,

        "headers": {
            "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://api.dicebear.com; font-src 'self'; connect-src 'self' https://icp0.io https://*.icp0.io https://ic0.app https://*.ic0.app https://icp-api.io https://api.coingecko.com; frame-src https://identity.ic0.app"
        }
    }
]
