# ClearDeck Environment Variables
# Copy this file to .env and fill in production values

# Beta Access Password Hash (SHA-256)
# Generate with: echo -n "yourpassword" | shasum -a 256 | cut -d' ' -f1
# Leave empty to disable password protection
VITE_BETA_PASSWORD_HASH=''

# Note: Canister IDs are managed by icp-cli via .icp/data/mappings/
# and injected to the frontend via the ic_env cookie.
# No additional environment variables are needed for canister IDs.
